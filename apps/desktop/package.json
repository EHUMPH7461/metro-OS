{
  "name": "metro-desktop",
  "version": "0.1.0",
  "description": "Metro OS desktop application",
  "main": "dist/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run vite\" \"npm run electron\" --names \"vite,electron\" --prefix-colors \"blue,green\"",
    "vite": "vite",
    "electron": "wait-on http://localhost:5173 && electron .",
    "build": "vite build && tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "lucide-react": "^0.376.0",
    "clsx": "^2.0.0",
    "date-fns": "^2.30.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.2.0",
    "electron": "^26.0.0",
    "eslint": "^8.45.0",
    "typescript": "^5.1.0",
    "vite": "^4.4.0",
    "vitest": "^0.34.0",
    "wait-on": "^7.0.0",
    "tailwindcss": "^3.3.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0"
  }
}
